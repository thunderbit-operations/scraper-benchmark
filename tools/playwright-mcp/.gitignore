# Never commit the local virtualenv (recreate via the README).
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/

# Run logs may carry absolute local paths — the JSON summaries carry the numbers.
*.log
*.out
*.stdout
artifacts/logs/

# Playwright MCP per-run output (snapshots/console/screenshots written to a temp
# --output-dir at runtime; the JSON summaries carry the measured numbers).
.playwright-mcp/

# OS noise
.DS_Store
