# Never commit the local virtualenv (harnesses are stdlib-only anyway).
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/

# Run logs may carry absolute local paths — the JSON summaries carry the numbers.
*.log
*.out
*.stdout
artifacts/logs/

# NEVER commit the Nutch distribution or any crawl state / large binaries.
apache-nutch-*/
*-bin.tar.gz
*-bin.zip
*.jar
crawldb/
segments/
linkdb/
hostdb/
dump_*/
seeds/
resume-*.cfg

# OS noise
.DS_Store
